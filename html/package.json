{
  "name": "blackmoon-admin-html",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "BlackMoon Admin Kit — HTML/Nunjucks template with Vite",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint public/assets/js/**/*.js",
    "lint:fix": "eslint public/assets/js/**/*.js --fix",
    "lint:css": "stylelint src/scss/**/*.scss",
    "lint:css:fix": "stylelint src/scss/**/*.scss --fix",
    "format": "prettier --write \"src/**/*.{html,scss}\" \"public/assets/js/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{html,scss}\" \"public/assets/js/**/*.js\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@phosphor-icons/web": "^2.1.1",
    "chart.js": "^4.4.7",
    "flag-icons": "^7.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "stylelint": "^17.8.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vite": "^8.0.5",
    "vite-plugin-nunjucks": "^0.2.0"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.scss": "stylelint --fix",
    "*.{html,md,json}": "prettier --write"
  }
}
